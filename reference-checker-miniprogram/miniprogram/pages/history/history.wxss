.history-page {
  min-height: 100vh;
  padding: 42rpx 24rpx calc(54rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.history-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin: 0 8rpx 30rpx;
}

.history-title {
  font-family: "Songti SC", serif;
  font-size: 46rpx;
  font-weight: 700;
}

.history-copy {
  margin-top: 4rpx;
  color: var(--muted);
  font-size: 22rpx;
}

.clear-history {
  margin: 0;
  color: var(--red);
  background: rgba(157, 64, 54, .07);
  font-size: 22rpx;
}

.state-card,
.record-card {
  border: 1rpx solid rgba(169, 157, 139, .62);
  border-radius: 24rpx;
  background: rgba(255, 253, 250, .94);
  box-shadow: 0 14rpx 42rpx rgba(36, 43, 55, .06);
}

.state-card {
  padding: 70rpx 34rpx;
  color: var(--muted);
  text-align: center;
}

.state-card button {
  margin-top: 22rpx;
}

.state-error {
  color: var(--red);
}

.empty-mark {
  color: #a99d8b;
  font-size: 58rpx;
}

.empty-title {
  margin-top: 12rpx;
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 700;
}

.empty-copy {
  margin-top: 8rpx;
  font-size: 23rpx;
}

.record-card {
  margin-bottom: 18rpx;
  padding: 28rpx;
}

.record-top,
.record-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.record-time {
  color: var(--muted);
  font-size: 21rpx;
}

.record-count {
  color: var(--red);
  font-size: 22rpx;
  font-weight: 700;
}

.record-input {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 20rpx;
  color: var(--ink);
  font-family: "Songti SC", serif;
  font-size: 25rpx;
  line-height: 1.68;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.record-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 18rpx;
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid var(--line);
  color: var(--muted);
  font-size: 21rpx;
}

.record-actions {
  justify-content: flex-end;
  margin-top: 22rpx;
}

.reuse-button,
.delete-button {
  margin: 0;
  padding: 0 18rpx;
  border-radius: 14rpx;
  font-size: 21rpx;
}

.reuse-button {
  color: #fff;
  background: var(--ink);
}

.delete-button {
  color: var(--red);
  background: transparent;
}

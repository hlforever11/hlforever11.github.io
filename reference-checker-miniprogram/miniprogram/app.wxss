page {
  --paper: #f3eee6;
  --card: #fffdfa;
  --ink: #182640;
  --muted: #6b7280;
  --line: #d8d0c3;
  --red: #9d4036;
  --green: #2f6d55;
  --amber: #94631f;
  min-height: 100%;
  color: var(--ink);
  background:
    radial-gradient(circle at 50% -80rpx, rgba(255,255,255,.95), rgba(255,255,255,0) 34%),
    linear-gradient(180deg, #f7f3ed 0%, var(--paper) 52%, #f5f0e9 100%);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.65;
}

button::after {
  border: 0;
}

.page-shell {
  padding: 0 24rpx calc(54rpx + env(safe-area-inset-bottom));
}

.card {
  background: rgba(255, 253, 250, .96);
  border: 1rpx solid rgba(169, 157, 139, .62);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 58rpx rgba(36, 43, 55, .07);
}

.button-primary,
.button-secondary,
.button-quiet {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 650;
}

.button-primary {
  color: #fff;
  background: linear-gradient(145deg, #223451, var(--ink));
  box-shadow: 0 10rpx 24rpx rgba(24, 38, 64, .14);
}

.button-primary[disabled] {
  color: rgba(255,255,255,.72);
  background: #9299a5;
  box-shadow: none;
}

.button-secondary {
  color: var(--ink);
  background: rgba(255,255,255,.82);
  border: 1rpx solid rgba(169, 157, 139, .72);
}

.button-quiet {
  color: var(--red);
  background: rgba(157, 64, 54, .07);
}

